#!/usr/bin/env bash
# juggle (jt) — ticket context manager
# https://github.com/JJwilkin/juggle-task

set -euo pipefail

JT_VERSION="0.2.0"
JT_CONFIG="$HOME/.jt-config"
JT_UPDATE_CACHE="$HOME/.jt-update-check"
JT_UPDATE_INTERVAL=86400  # check once per day
DEFAULT_TICKETS_DIR="$HOME/juggle-task"
REPO="JJwilkin/juggle-task"

_jt_tickets_dir() {
  local dir
  dir=$(cat "$JT_CONFIG" 2>/dev/null || true)
  [[ -z "$dir" ]] && dir="$DEFAULT_TICKETS_DIR"
  echo "$dir"
}

_jt_normalize_id() {
  echo "$1" | tr '[:lower:]' '[:upper:]'
}

_jt_get_branch() {
  local context_file="$1"
  grep "Working branch" "$context_file" 2>/dev/null | head -1 | sed 's/.*`\(.*\)`.*/\1/'
}

_jt_get_repo() {
  local context_file="$1"
  grep "^\*\*Repo\*\*" "$context_file" 2>/dev/null | head -1 | sed 's/\*\*Repo\*\*: //'
}

# Print a notice if a newer version is cached, then kick off a background
# refresh of the cache. Never blocks — network call is async.
_jt_check_update() {
  local now cached_time cached_version
  now=$(date +%s)

  # Read whatever is cached (instant, no network)
  if [[ -f "$JT_UPDATE_CACHE" ]]; then
    read -r cached_time cached_version < "$JT_UPDATE_CACHE" 2>/dev/null || true
    if [[ -n "$cached_version" && "$cached_version" != "$JT_VERSION" ]]; then
      printf '\n  Update available: %s → %s  (run '"'"'jt upgrade'"'"' to update)\n' \
        "$JT_VERSION" "$cached_version" >&2
    fi
    # Cache still fresh — no background fetch needed
    if [[ -n "${cached_time:-}" ]] && (( now - cached_time < JT_UPDATE_INTERVAL )); then
      return 0
    fi
  fi

  # Refresh cache in background — never blocks the current command
  (
    local latest
    latest=$(curl -fsSL --max-time 3 \
      "https://raw.githubusercontent.com/${REPO}/main/VERSION" \
      2>/dev/null | tr -d '[:space:]' || true)
    [[ -n "$latest" ]] && printf '%s %s\n' "$(date +%s)" "$latest" > "$JT_UPDATE_CACHE"
  ) &
  disown 2>/dev/null || true
}

_jt_pick_ticket() {
  local dir="$1"
  local ids=() titles=()

  for context in "$dir"/*/CONTEXT.md; do
    [[ -f "$context" ]] || continue
    local id title
    id=$(basename "$(dirname "$context")")
    title=$(head -1 "$context" 2>/dev/null \
      | sed 's/^# //' \
      | sed 's/ — Agent Context$//' \
      | sed 's/^[A-Za-z0-9-]*: //')
    ids+=("$id")
    titles+=("$title")
  done

  [[ ${#ids[@]} -eq 0 ]] && { echo "No tickets found. Run 'jt init <ticket>' first."; exit 1; }

  echo "Available tickets:"
  echo ""
  for i in "${!ids[@]}"; do
    printf "  %d) %-14s %s\n" "$((i+1))" "${ids[$i]}" "${titles[$i]}"
  done
  echo ""
  read -rp "Select (1-${#ids[@]}): " sel

  [[ "$sel" =~ ^[0-9]+$ ]] && (( sel >= 1 && sel <= ${#ids[@]} )) || {
    echo "Invalid selection."
    exit 1
  }

  _PICKED_TICKET="${ids[$((sel-1))]}"
}

_jt_checkout() {
  local ticket_id="$1" context_file="$2"
  local branch repo
  branch=$(_jt_get_branch "$context_file")
  repo=$(_jt_get_repo "$context_file")

  if [[ -n "$branch" && -n "$repo" && "$repo" != "(not in a git repo)" && "$repo" != "(none)" && -d "$repo" ]]; then
    if ! git -C "$repo" diff --quiet 2>/dev/null || ! git -C "$repo" diff --cached --quiet 2>/dev/null; then
      echo "Warning: $repo has uncommitted changes — branch not switched. Commit or stash first."
    else
      git -C "$repo" fetch origin --quiet 2>/dev/null || true
      git -C "$repo" checkout "$branch" 2>/dev/null \
        || git -C "$repo" checkout --track "origin/$branch" 2>/dev/null \
        || echo "Warning: could not switch to $branch (may already be on it)"
      echo "Branch: $branch"
    fi
  fi
}

cmd_help() {
  cat <<EOF
juggle (jt) v${JT_VERSION} — ticket context manager for Claude Code

Usage:
  jt init   <ticket> [--project <id>]   create ticket context (launches Claude)
  jt update                              save session progress to CONTEXT.md (launches Claude)
  jt open   [ticket]                     checkout branch + launch Claude with context pre-loaded
  jt ls                                  list all tracked tickets
  jt project init <id-or-url>            create a new project / epic
  jt project ls                          list all projects
  jt project show <id>                   show a project's PROJECT.md
  jt upgrade                             upgrade jt to the latest version
  jt config                              show current tickets directory
  jt config set <path>                   set tickets directory
  jt help                                show this message

Claude skills: /jt-init, /jt-update, /jt-project-init

Docs: https://github.com/JJwilkin/juggle-task
EOF
}

cmd_init() {
  # Parse args: <ticket> [--project <id>]
  local ticket="" project_id=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --project)
        project_id="${2:-}"
        shift 2
        ;;
      *)
        if [[ -z "$ticket" ]]; then
          ticket="$1"
        fi
        shift
        ;;
    esac
  done
  [[ -z "$ticket" ]] && { echo "Usage: jt init <TICKET-ID or URL> [--project <id>]"; exit 1; }

  local dir
  dir=$(_jt_tickets_dir)
  local skill_file="$HOME/.claude/skills/jt-init/SKILL.md"
  local args="$ticket"
  [[ -n "$project_id" ]] && args="$args --project $project_id"

  echo "Launching Claude to initialize $ticket${project_id:+ (project: $project_id)}..."
  echo ""
  if [[ -f "$skill_file" ]]; then
    local skill_body
    skill_body=$(awk 'BEGIN{p=0;n=0} /^---/{n++;if(n==2){p=1};next} p{print}' "$skill_file")
    skill_body="${skill_body//\$ARGUMENTS/$args}"
    claude -n "$ticket" --add-dir "$dir" \
      --append-system-prompt "$skill_body" \
      "/jt-init $args"
  else
    claude -n "$ticket" --add-dir "$dir" "/jt-init $args"
  fi
}

cmd_project() {
  local sub="${1:-}"
  shift || true
  local dir
  dir=$(_jt_tickets_dir)

  case "$sub" in
    init)
      local arg="${1:-}"
      [[ -z "$arg" ]] && { echo "Usage: jt project init <ID-or-Linear-URL>"; exit 1; }
      local skill_file="$HOME/.claude/skills/jt-project-init/SKILL.md"
      echo "Launching Claude to initialize project $arg..."
      echo ""
      if [[ -f "$skill_file" ]]; then
        local skill_body
        skill_body=$(awk 'BEGIN{p=0;n=0} /^---/{n++;if(n==2){p=1};next} p{print}' "$skill_file")
        skill_body="${skill_body//\$ARGUMENTS/$arg}"
        claude -n "Project: $arg" --add-dir "$dir" \
          --append-system-prompt "$skill_body" \
          "/jt-project-init $arg"
      else
        claude -n "Project: $arg" --add-dir "$dir" "/jt-project-init $arg"
      fi
      ;;
    ls)
      local found=0
      for project_file in "$dir"/projects/*/PROJECT.md; do
        [[ -f "$project_file" ]] || continue
        found=1; break
      done
      if [[ $found -eq 0 ]]; then
        echo "No projects found at: $dir/projects/"
        echo "Run 'jt project init <id>' to create your first project."
        return
      fi
      printf "%-14s  %-50s  %s\n" "PROJECT" "TITLE" "STATUS"
      printf "%-14s  %-50s  %s\n" "-------" "-----" "------"
      for project_file in "$dir"/projects/*/PROJECT.md; do
        [[ -f "$project_file" ]] || continue
        local id title status
        id=$(basename "$(dirname "$project_file")")
        title=$(head -1 "$project_file" 2>/dev/null | sed 's/^# //' | sed 's/^[A-Za-z0-9-]*: //')
        status=$(grep "^\*\*Status\*\*" "$project_file" 2>/dev/null | head -1 | sed 's/\*\*Status\*\*: //')
        printf "%-14s  %-50s  %s\n" "$id" "${title:0:50}" "${status:-(unknown)}"
      done
      ;;
    show)
      local id="${1:-}"
      [[ -z "$id" ]] && { echo "Usage: jt project show <id>"; exit 1; }
      local pfile="$dir/projects/$id/PROJECT.md"
      if [[ ! -f "$pfile" ]]; then
        # case-insensitive fallback: try uppercase
        local id_up
        id_up=$(_jt_normalize_id "$id")
        pfile="$dir/projects/$id_up/PROJECT.md"
      fi
      if [[ -f "$pfile" ]]; then
        cat "$pfile"
      else
        echo "No project found with id: $id"
        echo "Run 'jt project ls' to see available projects."
        exit 1
      fi
      ;;
    "")
      echo "Usage: jt project <init|ls|show> [args]"
      exit 1
      ;;
    *)
      echo "Unknown project subcommand: $sub"
      echo "Usage: jt project <init|ls|show> [args]"
      exit 1
      ;;
  esac
}

cmd_update() {
  local dir
  dir=$(_jt_tickets_dir)
  echo "Launching Claude to save session context..."
  echo ""
  claude --add-dir "$dir" "/jt-update $*"
}

cmd_ls() {
  local dir
  dir=$(_jt_tickets_dir)
  local found=0

  for context in "$dir"/*/CONTEXT.md; do
    [[ -f "$context" ]] || continue
    found=1; break
  done

  if [[ $found -eq 0 ]]; then
    echo "No tickets found at: $dir"
    echo "Run 'jt init <ticket>' to create your first ticket."
    return
  fi

  printf "%-14s  %-40s  %s\n" "TICKET" "TITLE" "LAST UPDATED"
  printf "%-14s  %-40s  %s\n" "------" "-----" "------------"

  for context in "$dir"/*/CONTEXT.md; do
    [[ -f "$context" ]] || continue
    local id title last_updated
    id=$(basename "$(dirname "$context")")
    title=$(head -1 "$context" 2>/dev/null | sed 's/^# //' | sed 's/ — Agent Context$//' | sed 's/^[A-Za-z0-9-]*: //')
    last_updated=$(grep "^\*\*Last updated\*\*" "$context" 2>/dev/null | head -1 | sed 's/\*\*Last updated\*\*: //')
    printf "%-14s  %-40s  %s\n" "$id" "${title:0:40}" "${last_updated:-(unknown)}"
  done
}


cmd_open() {
  local raw_id="${1:-}"
  local dir
  dir=$(_jt_tickets_dir)
  if [[ -z "$raw_id" ]]; then
    _jt_pick_ticket "$dir"
    raw_id="$_PICKED_TICKET"
    echo ""
  fi

  local ticket_id context_file
  # Try exact match, then uppercase — ticket dirs can be any case
  if [[ -d "$dir/$raw_id" ]]; then
    ticket_id="$raw_id"
  else
    ticket_id=$(_jt_normalize_id "$raw_id")
  fi
  context_file="$dir/$ticket_id/CONTEXT.md"

  [[ ! -f "$context_file" ]] && {
    echo "No context found for $ticket_id. Run 'jt init $ticket_id' first."
    exit 1
  }

  _jt_checkout "$ticket_id" "$context_file"

  local session_file="$dir/$ticket_id/.session"

  # Resume the saved session: cd to its original project dir then --resume by UUID
  if [[ -f "$session_file" ]]; then
    local session_dir session_uuid
    session_dir=$(head -1 "$session_file")
    session_uuid=$(sed -n '2p' "$session_file")
    if [[ -n "$session_dir" && -n "$session_uuid" && -d "$session_dir" ]]; then
      echo "Resuming session for $ticket_id..."
      echo ""
      cd "$session_dir" && claude --resume "$session_uuid"
      return
    fi
  fi

  # No saved session — start a fresh named session
  local session_name
  session_name=$(head -1 "$context_file" | sed 's/^# //' | sed 's/ — Agent Context$//')

  echo "Starting new session for $ticket_id..."
  echo ""
  claude -n "$session_name" --add-dir "$dir"
}

cmd_upgrade() {
  echo "Upgrading Juggle..."
  echo ""
  if curl -fsSL "https://raw.githubusercontent.com/${REPO}/main/install.sh" | bash; then
    rm -f "$JT_UPDATE_CACHE"
    echo ""
    echo "Upgraded to the latest version."
    echo "Restart Claude Code to load updated skills."
  else
    echo "Upgrade failed. Check your connection and try again."
    exit 1
  fi
}

cmd_config() {
  local subcmd="${1:-}"
  local dir
  dir=$(_jt_tickets_dir)

  case "$subcmd" in
    set)
      local new_path="${2:-}"
      [[ -z "$new_path" ]] && { echo "Usage: jt config set <path>"; exit 1; }
      new_path="${new_path/#\~/$HOME}"
      echo "$new_path" > "$JT_CONFIG"
      mkdir -p "$new_path"
      echo "Tickets directory set to: $new_path"
      ;;
    "")
      echo "Tickets directory: $dir"
      echo "Version:           $JT_VERSION"
      if [[ -f "$JT_CONFIG" ]]; then
        echo "Config file:       $JT_CONFIG"
      else
        echo "Config file:       (not set, using default)"
      fi
      ;;
    *)
      echo "Unknown config subcommand: $subcmd"
      echo "Usage: jt config [set <path>]"
      exit 1
      ;;
  esac
}

main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    init)           cmd_init "$@" ;;
    update)         cmd_update "$@" ;;
    open)           cmd_open "$@" ;;
    ls)             cmd_ls ;;
    project)        cmd_project "$@" ;;
    upgrade)        cmd_upgrade ;;
    config)         cmd_config "$@" ;;
    help|--help|-h) cmd_help ;;
    version|--version|-v) echo "jt $JT_VERSION" ;;
    *)
      echo "Unknown command: $cmd"
      echo "Run 'jt help' for usage."
      exit 1
      ;;
  esac

  # Check for updates after every command except upgrade/help/version
  case "$cmd" in
    upgrade|help|--help|-h|version|--version|-v) ;;
    *) _jt_check_update ;;
  esac
}

main "$@"
