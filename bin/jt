#!/usr/bin/env bash
# juggle (jt) — ticket context manager
# https://github.com/JJwilkin/juggle-task

set -euo pipefail

JT_VERSION="0.2.0"
JT_CONFIG="$HOME/.jt-config"
JT_UPDATE_CACHE="$HOME/.jt-update-check"
JT_UPDATE_INTERVAL=86400  # check once per day
DEFAULT_TICKETS_DIR="$HOME/juggle-tickets"
REPO="JJwilkin/juggle-task"

_jt_tickets_dir() {
  local dir
  dir=$(cat "$JT_CONFIG" 2>/dev/null || true)
  [[ -z "$dir" ]] && dir="$DEFAULT_TICKETS_DIR"
  echo "$dir"
}

_jt_normalize_id() {
  local raw="$1"
  if [[ "$raw" =~ ^[0-9]+$ ]]; then
    echo "PROJ-${raw}"
  else
    echo "${raw}" | tr '[:lower:]' '[:upper:]'
  fi
}

_jt_get_branch() {
  local context_file="$1"
  grep "Working branch" "$context_file" 2>/dev/null | head -1 | sed 's/.*`\(.*\)`.*/\1/'
}

_jt_get_repo() {
  local context_file="$1"
  grep "^\*\*Repo\*\*" "$context_file" 2>/dev/null | head -1 | sed 's/\*\*Repo\*\*: //'
}

# Print a notice if a newer version is cached, then kick off a background
# refresh of the cache. Never blocks — network call is async.
_jt_check_update() {
  local now cached_time cached_version
  now=$(date +%s)

  # Read whatever is cached (instant, no network)
  if [[ -f "$JT_UPDATE_CACHE" ]]; then
    read -r cached_time cached_version < "$JT_UPDATE_CACHE" 2>/dev/null || true
    if [[ -n "$cached_version" && "$cached_version" != "$JT_VERSION" ]]; then
      printf '\n  Update available: %s → %s  (run '"'"'jt upgrade'"'"' to update)\n' \
        "$JT_VERSION" "$cached_version" >&2
    fi
    # Cache still fresh — no background fetch needed
    if [[ -n "${cached_time:-}" ]] && (( now - cached_time < JT_UPDATE_INTERVAL )); then
      return 0
    fi
  fi

  # Refresh cache in background — never blocks the current command
  (
    local latest
    latest=$(curl -fsSL --max-time 3 \
      "https://raw.githubusercontent.com/${REPO}/main/VERSION" \
      2>/dev/null | tr -d '[:space:]' || true)
    [[ -n "$latest" ]] && printf '%s %s\n' "$(date +%s)" "$latest" > "$JT_UPDATE_CACHE"
  ) &
  disown 2>/dev/null || true
}

_jt_pick_ticket() {
  local dir="$1"
  local index="$dir/INDEX.md"

  [[ ! -f "$index" ]] && { echo "No tickets found. Run 'jt init <ticket>' first."; exit 1; }

  local ids=() titles=()
  while IFS= read -r line; do
    [[ "$line" =~ ^\|[[:space:]]\[([A-Z]+-[0-9]+)\] ]] || continue
    local id="${BASH_REMATCH[1]}"
    local title
    title=$(echo "$line" | cut -d'|' -f3 | xargs)
    ids+=("$id")
    titles+=("$title")
  done < "$index"

  [[ ${#ids[@]} -eq 0 ]] && { echo "No tickets found. Run 'jt init <ticket>' first."; exit 1; }

  echo "Available tickets:"
  echo ""
  for i in "${!ids[@]}"; do
    printf "  %d) %-12s %s\n" "$((i+1))" "${ids[$i]}" "${titles[$i]}"
  done
  echo ""
  read -rp "Select (1-${#ids[@]}): " sel

  [[ "$sel" =~ ^[0-9]+$ ]] && (( sel >= 1 && sel <= ${#ids[@]} )) || {
    echo "Invalid selection."
    exit 1
  }

  _PICKED_TICKET="${ids[$((sel-1))]}"
}

_jt_checkout() {
  local ticket_id="$1" context_file="$2"
  local branch repo
  branch=$(_jt_get_branch "$context_file")
  repo=$(_jt_get_repo "$context_file")

  if [[ -n "$branch" && -n "$repo" && "$repo" != "(not in a git repo)" && -d "$repo" ]]; then
    cd "$repo"
    git checkout "$branch" 2>/dev/null \
      || git checkout --track "origin/$branch" 2>/dev/null \
      || echo "Warning: could not switch branch (may already be on it)"
    echo "Branch: $branch"
  fi
}

cmd_help() {
  cat <<EOF
juggle (jt) v${JT_VERSION} — ticket context manager for Claude Code

Usage:
  jt init   <ticket>          create ticket context (launches Claude)
  jt update                   save session progress to CONTEXT.md (launches Claude)
  jt open   [ticket]          checkout branch + launch Claude with context pre-loaded
  jt ls                       list all tracked tickets
  jt upgrade                  upgrade jt to the latest version
  jt config                   show current tickets directory
  jt config set <path>        set tickets directory
  jt help                     show this message

Claude skills: /jt-init, /jt-update

Docs: https://github.com/JJwilkin/juggle-task
EOF
}

cmd_init() {
  local ticket="${1:-}"
  [[ -z "$ticket" ]] && { echo "Usage: jt init <TICKET-ID or URL>"; exit 1; }
  local dir
  dir=$(_jt_tickets_dir)
  local skill_file="$HOME/.claude/skills/jt-init/SKILL.md"
  echo "Launching Claude to initialize $ticket..."
  echo ""
  if [[ -f "$skill_file" ]]; then
    local skill_body
    # Strip YAML frontmatter (everything up to and including second ---) and substitute $ARGUMENTS
    skill_body=$(awk 'BEGIN{p=0;n=0} /^---/{n++;if(n==2){p=1};next} p{print}' "$skill_file" \
      | sed "s/\\\$ARGUMENTS/$ticket/g")
    claude -n "$ticket" --add-dir "$dir" \
      --append-system-prompt "$skill_body" \
      "/jt-init $ticket"
  else
    claude -n "$ticket" --add-dir "$dir" "/jt-init $ticket"
  fi
}

cmd_update() {
  local dir
  dir=$(_jt_tickets_dir)
  echo "Launching Claude to save session context..."
  echo ""
  claude --add-dir "$dir" "/jt-update $*"
}

cmd_ls() {
  local dir
  dir=$(_jt_tickets_dir)
  local index="$dir/INDEX.md"
  if [[ -f "$index" ]]; then
    cat "$index"
  else
    echo "No tickets found at: $dir"
    echo "Run 'jt init <ticket>' to create your first ticket."
  fi
}


cmd_open() {
  local raw_id="${1:-}"
  local dir
  dir=$(_jt_tickets_dir)
  if [[ -z "$raw_id" ]]; then
    _jt_pick_ticket "$dir"
    raw_id="$_PICKED_TICKET"
    echo ""
  fi

  local ticket_id
  ticket_id=$(_jt_normalize_id "$raw_id")
  local context_file="$dir/$ticket_id/CONTEXT.md"

  [[ ! -f "$context_file" ]] && {
    echo "No context found for $ticket_id. Run 'jt init $ticket_id' first."
    exit 1
  }

  _jt_checkout "$ticket_id" "$context_file"

  local session_name
  session_name=$(head -1 "$context_file" | sed 's/^# //' | sed 's/ — Agent Context$//')

  echo "Launching Claude for $ticket_id..."
  echo ""

  local context_content
  context_content=$(cat "$context_file")
  local intro_prompt
  intro_prompt="You are resuming work on $ticket_id. Here is the full context for this ticket:

$context_content

Briefly acknowledge where we left off and ask what I'd like to start with — or suggest the most logical next step from the Next Steps section."

  claude -n "$session_name" --add-dir "$dir" \
    --append-system-prompt "$intro_prompt" \
    "Ready to resume."
}

cmd_upgrade() {
  echo "Upgrading Juggle..."
  echo ""
  if curl -fsSL "https://raw.githubusercontent.com/${REPO}/main/install.sh" | bash; then
    rm -f "$JT_UPDATE_CACHE"
    echo ""
    echo "Upgraded to the latest version."
    echo "Restart Claude Code to load updated skills."
  else
    echo "Upgrade failed. Check your connection and try again."
    exit 1
  fi
}

cmd_config() {
  local subcmd="${1:-}"
  local dir
  dir=$(_jt_tickets_dir)

  case "$subcmd" in
    set)
      local new_path="${2:-}"
      [[ -z "$new_path" ]] && { echo "Usage: jt config set <path>"; exit 1; }
      new_path="${new_path/#\~/$HOME}"
      echo "$new_path" > "$JT_CONFIG"
      mkdir -p "$new_path"
      echo "Tickets directory set to: $new_path"
      ;;
    "")
      echo "Tickets directory: $dir"
      echo "Version:           $JT_VERSION"
      if [[ -f "$JT_CONFIG" ]]; then
        echo "Config file:       $JT_CONFIG"
      else
        echo "Config file:       (not set, using default)"
      fi
      ;;
    *)
      echo "Unknown config subcommand: $subcmd"
      echo "Usage: jt config [set <path>]"
      exit 1
      ;;
  esac
}

main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    init)           cmd_init "$@" ;;
    update)         cmd_update "$@" ;;
    open)           cmd_open "$@" ;;
    ls)             cmd_ls ;;
    upgrade)        cmd_upgrade ;;
    config)         cmd_config "$@" ;;
    help|--help|-h) cmd_help ;;
    version|--version|-v) echo "jt $JT_VERSION" ;;
    *)
      echo "Unknown command: $cmd"
      echo "Run 'jt help' for usage."
      exit 1
      ;;
  esac

  # Check for updates after every command except upgrade/help/version
  case "$cmd" in
    upgrade|help|--help|-h|version|--version|-v) ;;
    *) _jt_check_update ;;
  esac
}

main "$@"
